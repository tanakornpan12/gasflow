{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "forceConsistentCasingInFileNames": true,
    "lib": ["ES2022", "DOM"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noEmit": true,
    "noImplicitAny": false,
    "skipLibCheck": true,
    "strict": false,
    "target": "ES2022",
    "types": ["node"]
  },
  "include": [
    "backend/mailer.js",
    "backend/store/auth-utils.js",
    "mobile-app/src/api.js",
    "mobile-app/src/date.js",
    "mobile-app/src/mockData.js",
    "scripts/check-build.cjs",
    "scripts/check-module-contracts.cjs",
    "scripts/check-project-hygiene.cjs",
    "scripts/check-syntax.cjs",
    "scripts/run-unit-tests.cjs"
  ],
  "exclude": [
    ".codex",
    "artifacts",
    "build",
    "dist",
    "docs",
    "gasflow-ad-hyperframes",
    "gasflow-intro-video",
    "mobile-app/node_modules",
    "node_modules",
    "out",
    "second brain",
    "tmp"
  ]
}
